# ===== SQS 테스트용 환경변수 예시 =====
# 이 파일을 복사해서 .env 로 만들고 값을 채운 뒤 docker compose up 하세요.
#   cp .env.example .env
# .env 는 .gitignore 에 등록되어 커밋되지 않습니다.

# AWS 리전 (예: 서울 = ap-northeast-2)
AWS_REGION=ap-northeast-2

# 테스트할 SQS 큐의 전체 URL
SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/my-test-queue

# ===== IAM 자격증명 =====
# EC2 인스턴스에 IAM 역할(instance profile)이 붙어 있으면 아래 3개는 넣지 마세요.
# (역할이 자동으로 사용됩니다. 빈 값으로 두면 오히려 인증이 꼬일 수 있어 아예 주석 유지 권장)
#
# 액세스 키로 직접 인증할 때만 주석을 풀고 값을 채우세요:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
#
# STS 임시 자격증명(assume role 등)을 쓸 때만 추가로 필요:
# AWS_SESSION_TOKEN=...
